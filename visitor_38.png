<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Visitor Options | NRSC</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>

<body class="auth-body">

<div class="option-container">

    <h2>Visitor Services</h2>
    <p class="subtitle">Please choose an option</p>

    <div class="option-buttons">

        <a href="/visitor" class="btn-orange option-btn">
            Register Visitor
        </a>

        <a href="/visitor/status" class="btn-orange option-btn">
            Check Approval Status
        </a>
        
        <a href="{{ url_for('home') }}" class="btn-back">
            ⬅ Back to Home
        </a>
    </div>

</div>

</body>
</html>
